PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/jobhunt

# Google OAuth for Gmail send-only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Firebase Admin (Service Account)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Data-at-rest encryption (AES-256-GCM)
# 32-byte key as hex (64 chars) or base64
DATA_ENC_KEY=
# Identifier stored in encryption envelope for key rotation support
DATA_ENC_KEY_ID=key-v1
# HMAC secret used for derived lookup hashes (emailHash)
DATA_HASH_KEY=

# Comma-separated Gmail/email addresses that bypass app-level send throttles
# Example: RATE_LIMIT_BYPASS_EMAILS=me@example.com,alt@example.com
RATE_LIMIT_BYPASS_EMAILS=

# ── Resume Lab ─────────────────────────────────────────────────────────────
# Base URL for the Cortex intelligence service (no trailing slash)
CORTEX_BASE_URL=http://localhost:8000
# App name registered in the Cortex app registry (must match Cortex configuration)
CORTEX_APP_NAME=resumelab
# Absolute path where uploaded resume files are stored on disk
# Defaults to <project-root>/uploads/resumes if not set
RESUME_UPLOAD_DIR=
# Maximum resume upload size in megabytes (default: 10)
MAX_RESUME_UPLOAD_MB=10
# Temp directory used during LaTeX compilation (defaults to OS tmpdir/reachflow-latex)
LATEX_TEMP_DIR=
# Directory where compiled PDFs are saved per-user (defaults to <project-root>/uploads/pdfs)
PDF_OUTPUT_DIR=
