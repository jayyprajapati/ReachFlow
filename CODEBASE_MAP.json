{
  "project": {
    "name": "ReachFlow",
    "description": "Privacy-first job search platform: outreach, application tracking, AI resume tooling, DSA analysis, and learning roadmaps",
    "type": "fullstack-web-app",
    "tech": {
      "frontend": ["React 18", "Vite", "custom pushState router", "plain CSS"],
      "backend": ["Node.js", "Express", "CommonJS", "Firebase Admin SDK"],
      "database": "MongoDB (Mongoose)",
      "auth": "Firebase Auth",
      "ai": "Brain service (external Python LLM+RAG, port 8000)",
      "email": "Gmail API (OAuth2)",
      "pdf": "Docker reachflow-latex image"
    }
  },

  "areas": [
    {
      "name": "Frontend",
      "path": "frontend/src",
      "purpose": "React SPA — all user-facing pages and state",
      "documentation": "frontend/src/CLAUDE.md"
    },
    {
      "name": "Backend",
      "path": "backend/src",
      "purpose": "Express REST API — auth, encryption, Gmail, AI orchestration",
      "documentation": "backend/src/CLAUDE.md"
    },
    {
      "name": "Database Schemas",
      "path": "backend/src/db.js",
      "purpose": "All Mongoose schemas, model registrations, migration helpers"
    },
    {
      "name": "LaTeX Docker",
      "path": "backend/docker/latex",
      "purpose": "Docker image for LaTeX → PDF compilation (reachflow-latex)"
    },
    {
      "name": "LaTeX Resume Templates",
      "path": "backend/src/resume_templates",
      "purpose": "Role-specific .tex templates: backend.tex, frontend.tex, fullstack.tex, from-scratch.tex. Loaded and injected by latexCompiler.js injectTemplate()."
    },
    {
      "name": "Specs",
      "path": ".claude/specs",
      "purpose": "Product truth for all 13 features"
    },
    {
      "name": "Tasks",
      "path": ".claude/tasks",
      "purpose": "Engineering implementation tasks for all 13 features"
    }
  ],

