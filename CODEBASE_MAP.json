  "entities": [
    { "name": "User", "collection": "reachflow_users", "key_fields": ["firebaseUid", "encryptedRefreshToken", "gmailConnected", "senderDisplayNameEnc"] },
    { "name": "Campaign", "collection": "reachflow_outreach_items", "key_fields": ["userId", "status", "scheduledAt", "recipients[]", "encryptedPayload"] },
    { "name": "Group", "collection": "reachflow_groups", "key_fields": ["userId", "companyKey", "contacts[]"] },
    { "name": "Template", "collection": "reachflow_templates", "key_fields": ["userId", "encryptedPayload"] },
    { "name": "Variable", "collection": "reachflow_variables", "key_fields": ["userId", "variableNameKey", "encryptedPayload"] },
    { "name": "SendLog", "collection": "reachflow_send_logs", "key_fields": ["userId", "sentAt"] },
    { "name": "Application", "collection": "reachflow_applications", "key_fields": ["userId", "status", "companyGroupId", "encryptedPayload"] },
    { "name": "Resume", "collection": "reachflow_resumes", "key_fields": ["userId", "parsedDocId", "isBaseResume", "normalizedResumeText"] },
    { "name": "CanonicalProfile", "collection": "reachflow_canonical_profiles", "key_fields": ["userId", "profileVersion", "canonicalProfile"] },
    { "name": "ResumeAnalysis", "collection": "reachflow_resume_analyses", "key_fields": ["userId", "flowId", "matchScore", "matchAnalysis"] },
    { "name": "GeneratedResume", "collection": "reachflow_generated_resumes", "key_fields": ["userId", "analysisId", "flowId", "outputType", "latexSource", "pdfPath"] },
    { "name": "AISettings", "collection": "reachflow_ai_settings", "key_fields": ["userId", "provider", "apiKeyEncrypted", "isValid", "personalizationPrefs"] },
    { "name": "DsaAnalysis", "collection": "reachflow_dsa_analyses", "key_fields": ["userId", "problemStatement", "result", "status"] },
    { "name": "Roadmap", "collection": "reachflow_roadmaps", "key_fields": ["userId", "status", "progressPercent"] },
    { "name": "RoadmapStage", "collection": "reachflow_roadmap_stages", "key_fields": ["roadmapId", "userId", "order"] },
    { "name": "RoadmapItem", "collection": "reachflow_roadmap_items", "key_fields": ["roadmapId", "stageId", "userId", "status", "resourceType"] }
  ],

  "critical_files": [
    { "path": "backend/src/app.js", "reason": "Boot sequence, middleware, all route mounts, Gmail OAuth, requireAuth, account deletion" },
    { "path": "backend/src/db.js", "reason": "All Mongoose schemas and model registrations — source of truth for data shape" },
    { "path": "backend/src/utils/dataSecurity.js", "reason": "AES-256-GCM encrypt/decrypt and HMAC hash — touches every sensitive field" },
    { "path": "backend/src/utils/crypto.js", "reason": "Gmail refresh token encryption (TOKEN_ENC_KEY, separate key system)" },
    { "path": "backend/src/services/brainClient.js", "reason": "All LLM/RAG calls to Brain service — Resume Lab, DSA Lab, Compose rewrite" },
    { "path": "backend/src/services/brainPrompts.js", "reason": "All LLM prompt templates — change here to adjust AI behavior" },
    { "path": "backend/src/services/llmSettings.js", "reason": "BYOK enforcement — resolveUserLlm() gates all AI features" },
    { "path": "backend/src/services/latexCompiler.js", "reason": "LaTeX → PDF via Docker; owns injectTemplate() (role-specific .tex templates) and validateLatex()" },
    { "path": "backend/src/resume_templates/", "reason": "Role-specific LaTeX templates (backend/frontend/fullstack/from-scratch). Changes here affect all PDF layouts." },
    { "path": "backend/src/gmail.js", "reason": "Gmail OAuth helpers and send-from-user API calls" },
    { "path": "frontend/src/App.jsx", "reason": "Component tree root and top-level routing" },
    { "path": "frontend/src/router.jsx", "reason": "Custom pushState router — no React Router; navigate with useRouter().navigateTo()" },
    { "path": "frontend/src/contexts/AppContext.jsx", "reason": "Auth, Gmail state, groups, templates, history — shared across all pages" },
    { "path": "frontend/src/contexts/ResumeLabContext.jsx", "reason": "Resume Lab full state — all Resume Lab pages read from here" },
    { "path": "frontend/src/styles/tokens.css", "reason": "All CSS custom properties — retheme by editing here" }
  ],

  "flows": [
    {
      "name": "User Authentication",
      "steps": ["Firebase Auth (client)", "ID token issued", "AppContext stores token", "Every API call: Authorization header", "requireAuth: Firebase Admin verifyIdToken", "User.findOneAndUpdate (upsert)"]
    },
    {
      "name": "Gmail OAuth Connect",
      "steps": ["POST /gmail/connect", "Random state → User.gmailState", "Return Google OAuth URL", "User authorizes", "GET /auth/google/callback (public)", "State matched → exchangeCodeForUser", "Refresh token encrypted → User.encryptedRefreshToken", "Redirect /?gmail=success"]
    },
    {
      "name": "Resume Upload & Profile Build",
      "steps": ["POST /api/resumelab/resumes (multipart)", "File saved to disk", "brainClient.extractResume → /v1/extract (5 min)", "Resume doc saved", "brainClient.mergeCanonicalProfile → LLM merge", "CanonicalProfile updated + profileVersion++", "JD cache invalidated"]
    },
    {
      "name": "JD Analysis",
      "steps": ["POST /api/resumelab/analyze", "resolveUserLlm() BYOK check", "Check in-memory JD cache", "brainClient.analyzeResumeMatch → /v1/generate", "ResumeAnalysis doc saved", "Cache entry set (30 min TTL)"]
    },
    {
      "name": "Resume Generation (LaTeX → PDF)",
      "steps": ["POST /api/resumelab/generate { analysisId, intensity, templateType }", "resolveUserLlm()", "brainClient.generateResumeLatex → { latex_source }", "injectTemplate({ templateType }) → wraps into resume_templates/*.tex", "validateLatex → retry once if invalid", "compileToPdf → Docker reachflow-latex", "PDF saved to disk", "GeneratedResume doc saved (latexSource + pdfPath)"]
    },
    {
      "name": "Scheduled Campaign Send",
      "steps": ["setInterval 60s after Mongo connects", "Find campaigns: status=scheduled, scheduledAt<=now", "getAuthorizedClient(user)", "Gmail API send per recipient", "status → sent | failed"]
    }
  ],

  "documentation": {
    "root": ["CLAUDE.md", "ARCHITECTURE.md", "CODEBASE_MAP.json"],
    "areas": {
      "backend": "backend/src/CLAUDE.md",
      "frontend": "frontend/src/CLAUDE.md"
    },
    "specs": ".claude/specs/",
    "tasks": ".claude/tasks/"
  }
}
